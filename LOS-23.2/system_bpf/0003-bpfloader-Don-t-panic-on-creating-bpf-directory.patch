---
 loader/bpfloader.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/loader/bpfloader.rs b/loader/bpfloader.rs
index 1387ff5..c3e4f52 100644
--- a/loader/bpfloader.rs
+++ b/loader/bpfloader.rs
@@ -675,7 +675,7 @@ fn main() {
     info!("Loading legacy BPF progs");
 
     if let Err(e) = create_dir(Path::new("/sys/fs/bpf/vendor")) {
-        panic!("Error during mkdir /sys/fs/bpf/vendor: {e}");
+        error!("Error during mkdir /sys/fs/bpf/vendor: {e}");
     };
 
     // SAFETY: Linking in the existing legacy vendor bpfloader functionality.
